    function addMessage(text, type){
      const chatbox = document.getElementById("chatbox");
      const div = document.createElement("div");
      div.className = `msg ${type}`;
      div.textContent = text;
      chatbox.appendChild(div);
      chatbox.scrollTop = chatbox.scrollHeight;
    }

    function getTutorResponse(text){
      const msg = text.toLowerCase().trim();

      for(const item of tutorKnowledge){
        if(item.keys.some(k => msg.includes(k))){
          return item.answer;
        }
      }

      if(msg.includes("olá") || msg.includes("ola") || msg.includes("bom dia") || msg.includes("boa tarde")){
        return "Olá. Estou aqui para ajudar com Matemática, Física, fórmulas, exercícios, história dos cientistas e dúvidas sobre a Academia DAP. Podes perguntar livremente.";
      }

      if(msg.includes("formula") || msg.includes("fórmula")){
        return `Posso ajudar com fórmulas de Matemática e Física, incluindo isolamento de incógnitas. Se quiseres, escreve a fórmula ou o tema, por exemplo:
- “isola a velocidade em s = s0 + vt”
- “explica a fórmula da energia cinética”
- “como resolver uma equação exponencial?”`;
      }

      return `Ainda não tenho uma resposta específica pronta para essa pergunta nesta primeira parte da V3, mas posso ajudar se reformulares com o tema principal.

Exemplos:
- “explica equação exponencial”
- “fala sobre Newton”
- “o que é MRU?”
- “explica trabalho de uma força”
- “quem criou a Academia DAP?”`;
    }

    function sendMessage(){
      const input = document.getElementById("chatInput");
      const text = input.value.trim();
      if(!text) return;
      addMessage(text, "user");
      input.value = "";
      setTimeout(() => addMessage(getTutorResponse(text), "bot"), 250);
    }

    document.getElementById("chatInput").addEventListener("keydown", e => {
      if(e.key === "Enter") sendMessage();
    });
