    function renderTopics(data, containerId, searchText="", classFilter="todas", isPhysics=false){
      const container = document.getElementById(containerId);
      const term = searchText.toLowerCase().trim();

      const filtered = data.filter(item => {
        const matchesText =
          item.titulo.toLowerCase().includes(term) ||
          item.descricao.toLowerCase().includes(term) ||
          item.teoria.join(" ").toLowerCase().includes(term) ||
          item.formula.toLowerCase().includes(term) ||
          (item.historia || "").toLowerCase().includes(term);

        const matchesClass = classFilter === "todas" || item.classe === classFilter || (classFilter === "11" && item.classe === "11");
        return matchesText && matchesClass;
      });

      if(!filtered.length){
        container.innerHTML = `<div class="card"><p>Nenhum conteúdo encontrado para esse filtro.</p></div>`;
        return;
      }

      container.innerHTML = filtered.map((item, idx) => {
