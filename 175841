        if([ds,dt].some(x=>isNaN(x))) return setCalcOut("Preenche Δs e Δt.");
        return setCalcOut(`v = Δs/Δt\nv = ${ds}/${dt}\nv = ${ds/dt}`);
      }
      if(target==="ds"){
        if([v,dt].some(x=>isNaN(x))) return setCalcOut("Preenche v e Δt.");
        return setCalcOut(`Δs = v·Δt\nΔs = ${v}·${dt}\nΔs = ${v*dt}`);
      }
      if(target==="dt"){
        if([ds,v].some(x=>isNaN(x))) return setCalcOut("Preenche Δs e v.");
        return setCalcOut(`Δt = Δs/v\nΔt = ${ds}/${v}\nΔt = ${ds/v}`);
      }
    }

