                ${item.historia ? `
                  <div class="history-box">
                    <strong>Contexto histórico:</strong><br>
                    ${item.historia}
                  </div>
                ` : ""}

                ${isPhysics ? `<div class="pill">Classe ${item.classe}</div>` : `<div class="pill">Classe ${item.classe}</div>`}
