      if(target==="v"){
        if([Ec,m].some(x=>isNaN(x))) return setCalcOut("Preenche Ec e m.");
        return setCalcOut(`v = √(2Ec/m)\nv = √(2·${Ec}/${m})\nv = ${Math.sqrt((2*Ec)/m)}`);
      }
    }

    /* ========== GRÁFICOS ========== */
    const graphCanvas = document.getElementById("graphCanvas");
    const ctx = graphCanvas.getContext("2d");

    function drawAxes(){
      ctx.clearRect(0,0,graphCanvas.width,graphCanvas.height);
      ctx.fillStyle = "#0e1730";
      ctx.fillRect(0,0,graphCanvas.width,graphCanvas.height);

      const w = graphCanvas.width;
      const h = graphCanvas.height;
      const cx = w/2;
      const cy = h/2;

      ctx.strokeStyle = "rgba(255,255,255,.12)";
      ctx.lineWidth = 1;

      for(let x=0; x<=w; x+=40){
        ctx.beginPath();
        ctx.moveTo(x,0);
        ctx.lineTo(x,h);
        ctx.stroke();
      }
      for(let y=0; y<=h; y+=40){
        ctx.beginPath();
        ctx.moveTo(0,y);
        ctx.lineTo(w,y);
        ctx.stroke();
      }

      ctx.strokeStyle = "#dce9ff";
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(0,cy);
      ctx.lineTo(w,cy);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(cx,0);
      ctx.lineTo(cx,h);
      ctx.stroke();
    }

    function mapX(x){ return graphCanvas.width/2 + x*40; }
    function mapY(y){ return graphCanvas.height/2 - y*40; }

    function drawGraph(){
      const type = document.getElementById("graphType").value;
      const a = parseFloat(document.getElementById("gA").value) || 0;
      const b = parseFloat(document.getElementById("gB").value) || 0;
      const c = parseFloat(document.getElementById("gC").value) || 0;
      const exp = document.getElementById("graphExplanation");

      drawAxes();

      ctx.strokeStyle = "#7cc4ff";
      ctx.lineWidth = 3;
      ctx.beginPath();

      let started = false;
      for(let x=-9; x<=9; x+=0.05){
        let y = 0;
        if(type==="afim") y = a*x + b;
        if(type==="quad") y = a*x*x + b*x + c;
        if(type==="exp") y = Math.pow(a || 1, x);

        const px = mapX(x);
        const py = mapY(y);

        if(!started){
          ctx.moveTo(px, py);
          started = true;
        }else{
          ctx.lineTo(px, py);
        }
      }
      ctx.stroke();

      if(type==="afim"){
        exp.textContent =
`Função afim: f(x)=ax+b

Com os valores escolhidos:
f(x) = ${a}x + ${b}

Interpretação:
- a = coeficiente angular: controla a inclinação da reta.
- b = coeficiente linear: ponto onde a reta corta o eixo y.
- se a > 0, a reta cresce da esquerda para a direita.
- se a < 0, a reta decresce.`;
      }

      if(type==="quad"){
        exp.textContent =
`Função quadrática: f(x)=ax²+bx+c

Com os valores escolhidos:
f(x) = ${a}x² + ${b}x + ${c}

Interpretação:
- o gráfico é uma parábola.
- se a > 0, a concavidade é voltada para cima.
- se a < 0, a concavidade é voltada para baixo.
- as raízes, quando existem, são os pontos onde o gráfico corta o eixo x.`;
      }

      if(type==="exp"){
        exp.textContent =
`Função exponencial: f(x)=a^x

Com os valores escolhidos:
f(x) = ${a}^x

Interpretação:
- se a > 1, a função é crescente.
- se 0 < a < 1, a função é decrescente.
- o gráfico passa por (0,1), desde que a seja positiva e diferente de 1.`;
      }
    }

