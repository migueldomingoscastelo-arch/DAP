    function calcQuadratica(){
      const a = parseFloat(document.getElementById("qa").value);
      const b = parseFloat(document.getElementById("qb").value);
      const c = parseFloat(document.getElementById("qc").value);
      if([a,b,c].some(v=>isNaN(v))) return setCalcOut("Preenche a, b e c.");
      if(a===0) return setCalcOut("a não pode ser 0 numa equação do 2º grau.");

      const delta = b*b - 4*a*c;
      let txt = `Equação: ${a}x² + ${b}x + ${c} = 0\nΔ = b² - 4ac = ${delta}\n`;

      if(delta < 0){
        txt += "Não existem raízes reais.";
      }else{
        const x1 = (-b + Math.sqrt(delta))/(2*a);
        const x2 = (-b - Math.sqrt(delta))/(2*a);
        txt += `x1 = ${x1}\nx2 = ${x2}`;
      }
      setCalcOut(txt);
    }

    function calcAfim(){
      const a = parseFloat(document.getElementById("fa").value);
      const b = parseFloat(document.getElementById("fb").value);
      const x = parseFloat(document.getElementById("fx").value);
      if([a,b,x].some(v=>isNaN(v))) return setCalcOut("Preenche a, b e x.");
      const y = a*x + b;
      setCalcOut(`f(x)=ax+b\nf(${x})=${a}·${x}+${b}\nf(${x})=${y}`);
    }

    function calcMRU(){
      const target = document.getElementById("mruTarget").value;
      const s = parseFloat(document.getElementById("mruS").value);
      const s0 = parseFloat(document.getElementById("mruS0").value);
      const v = parseFloat(document.getElementById("mruV").value);
      const t = parseFloat(document.getElementById("mruT").value);

      if(target==="s"){
        if([s0,v,t].some(x=>isNaN(x))) return setCalcOut("Para calcular s, preenche s0, v e t.");
        return setCalcOut(`s = s0 + vt\ns = ${s0} + ${v}·${t}\ns = ${s0 + v*t}`);
      }
      if(target==="s0"){
        if([s,v,t].some(x=>isNaN(x))) return setCalcOut("Para calcular s0, preenche s, v e t.");
        return setCalcOut(`s0 = s - vt\ns0 = ${s} - ${v}·${t}\ns0 = ${s - v*t}`);
      }
      if(target==="v"){
        if([s,s0,t].some(x=>isNaN(x))) return setCalcOut("Para calcular v, preenche s, s0 e t.");
        return setCalcOut(`v = (s-s0)/t\nv = (${s}-${s0})/${t}\nv = ${(s-s0)/t}`);
      }
      if(target==="t"){
        if([s,s0,v].some(x=>isNaN(x))) return setCalcOut("Para calcular t, preenche s, s0 e v.");
        return setCalcOut(`t = (s-s0)/v\nt = (${s}-${s0})/${v}\nt = ${(s-s0)/v}`);
      }
    }

    function calcVelMedia(){
